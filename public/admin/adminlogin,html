<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Admin Login</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>

body{

    background:linear-gradient(135deg,#14B8A6,#0F766E);
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;

}

.login-card{

    width:430px;
    border:none;
    border-radius:25px;
    overflow:hidden;
    box-shadow:0 20px 40px rgba(0,0,0,.2);

}

.card-header{

    background:white;
    text-align:center;
    padding:35px;

}

.card-body{

    padding:40px;

}

.logo{

    font-size:70px;
    color:#14B8A6;

}

.form-control{

    border-radius:15px;
    padding:14px;

}

.btn-login{

    background:#14B8A6;
    color:white;
    padding:14px;
    border-radius:15px;
    font-size:18px;
    font-weight:600;

}

.btn-login:hover{

    background:#0F766E;
    color:white;

}

</style>

</head>

<body>

<div class="card login-card">

<div class="card-header">

<i class="bi bi-shield-lock-fill logo"></i>

<h2 class="mt-3">
Admin Login
</h2>

<p class="text-muted">
Diabetic Retinopathy Screening System
</p>

</div>

<div class="card-body">

<form id="adminLoginForm">

<div class="mb-4">

<label class="form-label">

Username

</label>

<input
type="text"
id="username"
class="form-control"
placeholder="Enter Username">

</div>

<div class="mb-4">

<label class="form-label">

Password

</label>

<input
type="password"
id="password"
class="form-control"
placeholder="Enter Password">

</div>

<button
type="submit"
class="btn btn-login w-100">

<i class="bi bi-box-arrow-in-right"></i>

Login

</button>

</form>

</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script src="../js/adminLogin.js"></script>

</body>
</html>